{
	"name": "cno-plugin-cno-blocks",
	"version": "2.6.0",
	"description": "Blocks for the CNO Site",
	"author": "Choctaw Nation of Oklahoma",
	"license": "GPL-3.0-or-later",
	"prettier": "@wordpress/prettier-config",
	"homepage": "https://github.com/choctaw-naton/cno-plugin-cno-blocks",
	"main": "build/index.js",
	"scripts": {
		"build": "wp-scripts build --blocks-manifest --webpack-copy-php --config webpack.config.mjs --experimental-modules",
		"format": "wp-scripts format",
		"lint:css": "npx stylelint '**/*.scss' --fix",
		"lint:js": "npx eslint '**/*.{js,ts,jsx,tsx}' --fix",
		"packages-update": "wp-scripts packages-update",
		"plugin-zip": "npm run build && wp-scripts plugin-zip",
		"start": "wp-scripts start --blocks-manifest --webpack-copy-php --config webpack.config.mjs --experimental-modules"
	},
	"files": [
		"inc",
		"vendor",
		"build",
		"cno-plugin-cno-blocks.php",
		"README.md"
	],
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@wordpress/api-fetch": "^7.49.0",
		"@wordpress/block-editor": "^15.22.0",
		"@wordpress/blocks": "^15.22.0",
		"@wordpress/components": "^36.0.0",
		"@wordpress/compose": "^8.2.0",
		"@wordpress/core-data": "^7.49.0",
		"@wordpress/data": "^10.49.0",
		"@wordpress/date": "^5.49.0",
		"@wordpress/dom-ready": "^4.49.0",
		"@wordpress/editor": "^14.49.0",
		"@wordpress/element": "^8.1.0",
		"@wordpress/eslint-plugin": "^25.5.0",
		"@wordpress/icons": "^15.0.0",
		"@wordpress/interactivity": "^6.49.0",
		"@wordpress/scripts": "^32.5.0",
		"clsx": "^2.1.1",
		"eslint": "^9",
		"globals": "^17.7.0",
		"prettier": "npm:wp-prettier@^3.0.3",
		"stylelint": "^17.14.0",
		"stylelint-config-standard-scss": "^17.0.0",
		"stylelint-scss": "^7.2.0",
		"typescript": "^6.0.3"
	},
	"allowScripts": {
		"@parcel/watcher@2.5.6": true,
		"core-js@3.49.0": true,
		"core-js-pure@3.49.0": true,
		"fsevents@2.3.3": true,
		"fsevents@2.3.2": true,
		"unrs-resolver@1.11.1": true
	}
}
