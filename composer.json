{
	"name": "choctaw-nation/cno-blocks",
	"description": "Blocks for Choctaw Nation of Oklahoma website",
	"type": "project",
	"version": "2.3.0",
	"autoload": {
		"classmap": [
			"inc/"
		]
	},
	"repositories": [
		{
			"type": "composer",
			"url": "https://wpackagist.org",
			"only": [
				"wpackagist-plugin/*",
				"wpackagist-theme/*"
			]
		},
		{
			"type": "composer",
			"url": "https://composer.advancedcustomfields.com"
		}
	],
	"extra": {
		"installer-paths": {
			"vendor/{$name}/": [
				"wpengine/advanced-custom-fields"
			]
		}
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true,
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"scripts": {
		"phpcs": "phpcs inc/ src/blocks/ cno-plugin-cno-blocks.php",
		"phpcbf": "phpcbf inc/ src/blocks/ cno-plugin-cno-blocks.php"
	},
	"require-dev": {
		"wp-coding-standards/wpcs": "*",
		"php-stubs/acf-pro-stubs": "*"
	}
}
