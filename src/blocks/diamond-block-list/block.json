{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "cno/diamond-button-list",
	"version": "1.0.0",
	"title": "Diamond Button List",
	"category": "text",
	"icon": "button",
	"description": "Display a list of stylized, diamond-shaped buttons",
	"allowedBlocks": [ "cno/diamond-button-list-item" ],
	"attributes": {
		"listType": {
			"type": "string",
			"enum": [ "ordered", "unordered" ],
			"default": "unordered"
		},
		"btnColor": {
			"type": "string",
			"default": "primary"
		},
		"btnColorHSL": {
			"type": "object",
			"default": {
				"h": "",
				"s": "",
				"l": ""
			}
		},
		"btnBgColor": {
			"type": "string",
			"default": "light"
		}
	},
	"supports": {
		"html": false,
		"anchor": false,
		"customClassName": false,
		"color": {
			"text": false,
			"background": false
		},
		"spacing": {
			"blockGap": true,
			"margin": false,
			"padding": false
		}
	},
	"editorScript": "file:./index.tsx",
	"style": "file:./style-index.css"
}
