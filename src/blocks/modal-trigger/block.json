{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "cno/modal-trigger",
	"version": "1.1.2",
	"title": "Modal Trigger",
	"category": "design",
	"icon": "block-default",
	"description": "Modal Trigger",
	"example": {},
	"keywords": [ "button", "modal", "trigger" ],
	"attributes": {
		"buttonText": {
			"type": "string",
			"default": "More Info"
		},
		"source": {
			"type": "string",
			"default": "innerblocks",
			"enum": [ "cnhsa-guidelines", "innerblocks" ]
		},
		"gformId": {
			"type": "number"
		},
		"modalTitle": {
			"type": "string",
			"default": "More Information"
		},
		"closeWithBackdropClick": {
			"type": "boolean",
			"default": true
		},
		"allowBodyScrollWhileOpen": {
			"type": "boolean",
			"default": false
		}
	},
	"supports": {
		"html": false,
		"align": false,
		"color": {
			"text": true,
			"background": true
		},
		"spacing": {
			"padding": true,
			"margin": true
		},
		"typography": {
			"fontSize": true,
			"fontFamily": true
		},
		"dimensions": {
			"width": false
		},
		"interactivity": true
	},
	"editorScript": "file:./index.tsx",
	"style": "file:./style-index.css",
	"styles": [
		{
			"name": "solid",
			"label": "Solid",
			"isDefault": true
		},
		{
			"name": "outline",
			"label": "Outline"
		},
		{
			"name": "link",
			"label": "Link"
		}
	]
}
