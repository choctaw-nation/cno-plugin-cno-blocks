{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "cno/acf-related-events",
	"title": "ACF Related Events",
	"description": "A block for displaying related events set with the ACF field.",
	"category": "widgets",
	"supports": {
		"html": false,
		"reusable": false,
		"multiple": false,
		"alignWide": true,
		"align": true,
		"color": {
			"text": true,
			"background": false
		},
		"typography": {
			"fontSize": true
		}
	},
	"attributes": {
		"dateFormat": {
			"type": "string",
			"default": "M d"
		}
	},
	"editorScript": "file:./index.tsx",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
