{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "cno/diamond-button",
	"version": "0.1.0",
	"title": "Diamond Button",
	"category": "design",
	"icon": "button",
	"description": "Display a stylized, diamond-shaped button",
	"allowedBlocks": [
		"core/paragraph",
		"cno/modal-trigger",
		"font-awesome/icon"
	],
	"attributes": {
		"btnColor": {
			"type": "string",
			"default": "primary"
		},
		"btnColorHSL": {
			"type": "object",
			"default": {
				"h": "",
				"s": "",
				"l": ""
			}
		},
		"btnBgColor": {
			"type": "string",
			"default": "light"
		}
	},
	"supports": {
		"html": false,
		"anchor": false,
		"customClassName": false,
		"color": {
			"text": false,
			"background": false
		},
		"spacing": {
			"margin": true
		}
	},
	"editorScript": "file:./index.tsx",
	"style": "file:./style-index.css"
}
